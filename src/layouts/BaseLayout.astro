---
/**
 * BaseLayout — casca HTML única de todas as páginas.
 * Head via componente SEO (aceita o `head` fiel capturado do export, ou props
 * simples). Tipografia (Google Fonts), favicons, manifest, rastreamento e chrome
 * (Header/Footer via componentes). JSON-LD por página entra pelo slot "jsonld".
 */
// ETAPA 12 — fontes auto-hospedadas (sem dependência do Google Fonts).
// Apenas o subconjunto latino e os pesos realmente usados (400/500/600/700),
// todos com font-display: swap. Os arquivos .woff2 são versionados no build.
import '@fontsource/manrope/latin-400.css';
import '@fontsource/manrope/latin-500.css';
import '@fontsource/manrope/latin-600.css';
import '@fontsource/manrope/latin-700.css';
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource/inter/latin-700.css';
import '@/styles/tokens.css';
import '@/styles/base.css';
import '@/styles/ui.css';
import '@/styles/prose.css';
import '@/styles/institucional.css';
import SEO from '@/components/SEO.astro';
import Analytics from '@/components/Analytics.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import FloatingWhatsApp from '@/components/FloatingWhatsApp.astro';
import ConsentBanner from '@/components/ConsentBanner.astro';
import { site } from '@/lib/site.config';
import type { PageHead } from '@/lib/institucional';

interface Props {
  head?: PageHead;
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  noCanonical?: boolean;
}
const { head, title, description, canonical, noindex, noCanonical } = Astro.props;
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content={site.themeColor} />
    {site.analytics.searchConsoleVerification && (
      <meta name="google-site-verification" content={site.analytics.searchConsoleVerification} />
    )}

    <SEO
      head={head}
      title={title}
      description={description}
      canonical={canonical}
      noindex={noindex}
      noCanonical={noCanonical}
    />

    {/* Tipografia — Manrope + Inter auto-hospedadas (import no topo, sem
        requisição externa ao Google Fonts). font-display: swap embutido. */}

    {/* Favicons e manifest (martelo verde) — ?v= força atualização de cache */}
    <link rel="icon" href="/favicon.ico?v=2" sizes="32x32" />
    <link rel="icon" href="/favicon.svg?v=2" type="image/svg+xml" />
    <link rel="icon" href="/favicon-16x16.png?v=2" type="image/png" sizes="16x16" />
    <link rel="icon" href="/favicon-32x32.png?v=2" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Conteúdos — Corrêa Lima Advocacia" href="/rss.xml" />

    {/* Dados estruturados por página */}
    <slot name="jsonld" />

    <Analytics />
  </head>
  <body>
    <a href="#conteudo-principal" class="skip-link">Pular para o conteúdo</a>
    <Header />
    <slot />
    <Footer />
    <FloatingWhatsApp />
    <ConsentBanner />
    <script>
      // Revelação sutil ao rolar — aplica-se a [data-reveal] e, de forma
      // automática, aos cartões/itens repetidos usados em todo o site
      // (áreas, guias, blog, FAQ etc.), sem exigir alteração de cada página.
      // Sem dependências externas; respeita prefers-reduced-motion (base.css).
      const AUTO_SELECTOR = [
        '.ncard', '.destaque', '.conteudo', '.dif', '.problem-grid li',
        '.faq-item', '.rel a', '.risk-grid li', '.card',
        '.p-hero-card', '.tl-step',
      ].join(',');

      document.querySelectorAll(AUTO_SELECTOR).forEach((el) => {
        if (!el.hasAttribute('data-reveal')) el.setAttribute('data-reveal', '');
      });

      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
      );
      document.querySelectorAll('[data-reveal]').forEach((el, i) => {
        (el as HTMLElement).style.transitionDelay = `${Math.min(i % 6, 5) * 60}ms`;
        io.observe(el);
      });
    </script>
  </body>
</html>
