---
/**
 * /blog/[slug]/ — rota dinâmica das páginas da coleção "blog" (Fase 4).
 * Conteúdo em Markdown (Content Collection); head e JSON-LD preservados.
 */
import { getCollection, render } from 'astro:content';
import EntryPage from '@/layouts/EntryPage.astro';
import { buildChildHead } from '@/lib/child-head';
import { getJsonLd, getBreadcrumb, buildArticleJsonLd, buildFaqJsonLd, buildBreadcrumbCrumbs } from '@/lib/structured-data';
import ContextualCta from '@/components/editorial/ContextualCta.astro';
import ClusterNav from '@/components/editorial/ClusterNav.astro';
import RelatedContent from '@/components/editorial/RelatedContent.astro';
import { getNucleo } from '@/lib/nucleos';

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const path = `/blog/${entry.id}/`;
const head = buildChildHead('blog', entry.data, path);
const preserved = getJsonLd('blog', entry.id);
const isNew = preserved.length === 0;
// FAQPage é gerado sempre que houver seção "Perguntas frequentes" visível —
// inclusive em artigos legados reescritos, cujo schema preservado não a inclui.
const faq = buildFaqJsonLd(entry.body ?? '');
const preservedTemFaq = preserved.some((x) => (x as { '@type'?: string })['@type'] === 'FAQPage');
const jsonld = isNew
  ? [
      ...buildArticleJsonLd({
        collection: 'blog',
        slug: entry.id,
        title: entry.data.title,
        description: entry.data.description,
        h1: entry.data.h1,
        author: entry.data.author,
        pubDate: (entry.data as { pubDate?: Date }).pubDate,
        updatedDate: entry.data.updatedDate,
      }),
      ...(faq ? [faq] : []),
    ]
  : [...preserved, ...(faq && !preservedTemFaq ? [faq] : [])];
const crumbs = isNew ? buildBreadcrumbCrumbs('blog', entry.data.h1) : getBreadcrumb('blog', entry.id);

// Integração editorial: CTA contextual + relacionados a partir do frontmatter.
const nucleo = entry.data.cluster ? getNucleo(entry.data.cluster) : undefined;
const relacionados = entry.data.relacionados ?? [];
---

<EntryPage head={head} jsonld={jsonld} crumbs={crumbs}>
  <Content />
  {relacionados.length > 0 && <RelatedContent itens={relacionados} />}
  <ClusterNav cluster={entry.data.cluster} currentSlug={entry.id} currentCollection="blog" />
  <ContextualCta
    titulo={nucleo ? `Precisa de orientação em ${nucleo.label}?` : 'Precisa avaliar a sua situação?'}
    texto="Apresente o caso e entenda quais podem ser os próximos passos."
    areaHref={nucleo?.href}
  />
</EntryPage>
