---
/**
 * PillarPage — layout compartilhado das seis páginas-pilar (Sprint 1).
 * Recebe `slug` e monta a página completa a partir de src/lib/nucleos.ts:
 * head (title/description exclusivos), JSON-LD (BreadcrumbList + Service +
 * FAQPage), breadcrumb, hero, problemas, serviços, para quem, como atuamos,
 * FAQ, conteúdos/áreas relacionados e CTA final. Um único h1 por página.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import JsonLd from '@/components/JsonLd.astro';
import Icon from '@/components/Icon.astro';
import { site, whatsappHrefForPath } from '@/lib/site.config';
import { getNucleo } from '@/lib/nucleos';
import { pillarExtra } from '@/lib/pillar-extra';
import { getSubtopicsByNucleo } from '@/lib/subtopics';
import type { PageHead } from '@/lib/institucional';

interface Props { slug: string }
const { slug } = Astro.props;
const n = getNucleo(slug)!;
const waHref = whatsappHrefForPath(`/areas-de-atuacao/${slug}/`); // ETAPA 18
const extra = pillarExtra[slug];
const subs = getSubtopicsByNucleo(slug);
const guideForNucleo: Record<string, { slug: string; label: string }> = {
  'recuperacao-de-credito': { slug: 'cobranca-execucao-e-recuperacao-de-credito-empresarial', label: 'Guia completo de cobrança, execução e recuperação de crédito' },
  'cobranca-condominial': { slug: 'cobranca-condominial-guia-completo', label: 'Guia completo da cobrança condominial' },
  'direito-ambiental': { slug: 'direito-ambiental-guia-completo', label: 'Guia completo do direito ambiental' },
  'direito-aduaneiro-tributario': { slug: 'direito-aduaneiro-tributario-guia-completo', label: 'Guia completo do direito aduaneiro-tributário' },
  'direito-internacional': { slug: 'homologacao-de-sentenca-estrangeira-no-brasil', label: 'Guia completo da homologação de sentença estrangeira' },
  'inventario-e-patrimonio': { slug: 'inventario-guia-completo', label: 'Guia completo do inventário' },
};
const guide = guideForNucleo[slug];

const canonical = `${site.url}${n.href}`;
const title = `${n.seoTitle} | ${site.name}`;
const ogImage = `${site.url}${site.ogImage}`;

const head: PageHead = {
  title,
  description: n.seoDescription,
  canonical,
  robots: 'index, follow',
  og: {
    title,
    description: n.seoDescription,
    url: canonical,
    type: 'website',
    site_name: site.name,
    locale: site.locale,
    image: ogImage,
  },
  twitter: { card: 'summary_large_image', title, description: n.seoDescription, image: ogImage },
};

const steps = [
  { nn: '01', t: 'Análise inicial da situação', d: 'Entendemos o problema, o objetivo e o contexto — sem compromisso.' },
  { nn: '02', t: 'Avaliação documental e estratégia', d: 'Analisamos os documentos e definimos a estratégia adequada ao caso.' },
  { nn: '03', t: 'Medidas cabíveis', d: 'Conduzimos as medidas extrajudiciais, administrativas ou judiciais pertinentes.' },
  { nn: '04', t: 'Acompanhamento', d: 'Acompanhamos o andamento e comunicamos cada etapa com clareza.' },
];

const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${site.url}/` },
      { '@type': 'ListItem', position: 2, name: 'Áreas de Atuação', item: `${site.url}/areas-de-atuacao/` },
      { '@type': 'ListItem', position: 3, name: n.label, item: canonical },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: n.label,
    name: n.seoTitle,
    description: n.seoDescription,
    areaServed: 'BR',
    url: canonical,
    provider: {
      '@type': 'LegalService',
      name: site.name,
      url: `${site.url}/`,
      email: site.contact.email,
      telephone: site.contact.whatsapp.display,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: n.faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---

<BaseLayout head={head}>
  <Fragment slot="jsonld">
    {jsonld.map((schema) => <JsonLd schema={schema} />)}
  </Fragment>

  <main id="conteudo-principal" class="pillar">
    <!-- Hero -->
    <section class="p-hero">
      <div class="wrap">
        <nav class="crumbs" aria-label="Você está em">
          <a href="/">Início</a><span aria-hidden="true">/</span>
          <a href="/areas-de-atuacao/">Áreas de Atuação</a><span aria-hidden="true">/</span>
          <span>{n.label}</span>
        </nav>
        <div class="p-hero-grid">
          <div>
            <p class="eyebrow"><span class="dot"></span>{n.eyebrow}</p>
            <h1>{n.h1}</h1>
            <p class="p-hero-desc">{n.heroDescription}</p>
            <div class="p-cta">
              <a class="btn btn--primary" href={waHref} target="_blank" rel="noopener noreferrer">Falar com um advogado</a>
              <a class="btn btn--secondary" href="/contato/">Solicitar análise inicial</a>
            </div>
          </div>
          <aside class="p-hero-card" aria-label="Resumo">
            <span class="p-hero-ic"><Icon name={n.icon} size={28} /></span>
            <p class="p-hero-card-t">{n.short}</p>
          </aside>
        </div>
      </div>
    </section>

    <!-- Entenda o problema -->
    <section class="p-sec p-sec--white">
      <div class="wrap wrap--narrow">
        <p class="eyebrow"><span class="dot"></span>O problema</p>
        <h2>Entenda o problema</h2>
        <p class="p-lead">{extra?.problem}</p>
      </div>
    </section>

    <!-- Problemas atendidos -->
    <section class="p-sec p-sec--white">
      <div class="wrap">
        <p class="eyebrow"><span class="dot"></span>O que resolvemos</p>
        <h2>Situações em que atuamos</h2>
        <ul class="check-grid">
          {n.situations.map((s) => (
            <li><Icon name="check" size={18} class="ck" /><span>{s}</span></li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Serviços -->
    <section class="p-sec p-sec--paper">
      <div class="wrap">
        <p class="eyebrow"><span class="dot"></span>Serviços</p>
        <h2>O que a atuação abrange</h2>
        <ul class="chip-grid">
          {n.services.map((s) => <li>{s}</li>)}
        </ul>
      </div>
    </section>

    <!-- Riscos -->
    <section class="p-sec p-sec--white">
      <div class="wrap">
        <p class="eyebrow"><span class="dot"></span>Riscos de não agir</p>
        <h2>Por que o tempo importa</h2>
        <ul class="risk-grid">
          {(extra?.risks ?? []).map((r) => (<li><Icon name="shield" size={18} class="rk" /><span>{r}</span></li>))}
        </ul>
      </div>
    </section>

    <!-- CTA intermediário -->
    <section class="p-cta-mid">
      <div class="wrap cta-mid-inner">
        <p>Cada situação tem particularidades. Vamos avaliar a sua?</p>
        <a class="btn btn--primary" href="/contato/">Solicitar análise inicial</a>
      </div>
    </section>

    <!-- Temas específicos (subpáginas) -->
    {subs.length > 0 && (
      <section class="p-sec p-sec--paper">
        <div class="wrap">
          <p class="eyebrow"><span class="dot"></span>Temas específicos</p>
          <h2>Explore em profundidade</h2>
          <ul class="sub-grid">
            {subs.map((x) => (
              <li><a href={`/areas-de-atuacao/${x.nucleo}/${x.slug}/`}><strong>{x.label}</strong><span>{x.seoDescription}</span><Icon name="arrow-right" size={16} class="sg-arrow" /></a></li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- Guia completo (linkagem pilar -> guia) -->
    {guide && (
      <section class="p-sec p-guide-band">
        <div class="wrap guide-inner">
          <div>
            <p class="eyebrow"><span class="dot"></span>Aprofunde no tema</p>
            <h2>{guide.label}</h2>
            <p class="p-lead">Um material de referência, organizado do básico ao avançado, para entender o tema com profundidade antes de decidir os próximos passos.</p>
          </div>
          <a class="btn btn--primary" href={`/guias/${guide.slug}/`}>Ler o guia completo</a>
        </div>
      </section>
    )}

    <!-- Para quem / Como atuamos -->
    <section class="p-sec p-sec--white">
      <div class="wrap two-col">
        <div>
          <p class="eyebrow"><span class="dot"></span>Para quem</p>
          <h2>A quem se destina</h2>
          <ul class="check-grid check-grid--single">
            {n.forWhom.map((w) => (
              <li><Icon name="users" size={18} class="ck" /><span>{w}</span></li>
            ))}
          </ul>
        </div>
        <div>
          <p class="eyebrow"><span class="dot"></span>Como atuamos</p>
          <h2>Do contato à condução</h2>
          <ol class="steps">
            {steps.map((s) => (
              <li><span class="s-n">{s.nn}</span><div><strong>{s.t}</strong><p>{s.d}</p></div></li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="p-sec p-sec--paper">
      <div class="wrap wrap--narrow">
        <p class="eyebrow"><span class="dot"></span>Perguntas frequentes</p>
        <h2>Dúvidas comuns</h2>
        <div class="faq">
          {n.faq.map((f) => (
            <details class="faq-item">
              <summary>{f.q}<span class="faq-mark" aria-hidden="true"></span></summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
        <p class="faq-note">As respostas têm caráter informativo geral e não substituem a análise individual do caso.</p>
      </div>
    </section>

    <!-- Relacionados -->
    <section class="p-sec p-sec--white">
      <div class="wrap">
        <p class="eyebrow"><span class="dot"></span>Conteúdos e áreas relacionadas</p>
        <h2>Explore também</h2>
        <ul class="rel-grid">
          {n.related.map((r) => (
            <li><a href={r.href}>{r.label}<Icon name="arrow-right" size={16} /></a></li>
          ))}
        </ul>
      </div>
    </section>

    <!-- CTA final -->
    <section class="p-sec p-sec--navy">
      <div class="wrap cta-inner">
        <div>
          <h2 class="cta-title">Entenda os riscos e as medidas possíveis para o seu caso</h2>
          <p class="cta-text">Entre em contato para uma análise inicial da situação e dos documentos disponíveis.</p>
        </div>
        <div class="cta-actions">
          <a class="btn btn--primary" href="/contato/">Solicitar atendimento</a>
          <a class="btn btn--ghost-light" href={waHref} target="_blank" rel="noopener noreferrer">Falar no WhatsApp</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* PillarPage — identidade própria (hero editorial claro), sistema compartilhado.
     Botões, eyebrow, faq, crumbs e chips vêm de ui.css (global). */
  .pillar :where(h2) {
    font-size: var(--text-2xl);
    color: var(--color-ink);
    margin-top: var(--space-2);
  }

  /* Hero claro */
  .p-hero {
    background: var(--surface-warm);
    padding-block: var(--section-y-sm);
    border-bottom: 1px solid var(--border-subtle);
  }
  .p-hero .crumbs { margin-bottom: var(--space-4); }
  .p-hero-grid { display: grid; gap: var(--space-6); align-items: center; }
  @media (min-width: 900px) { .p-hero-grid { grid-template-columns: 1.6fr 1fr; gap: var(--space-12); } }
  .p-hero h1 {
    font-size: var(--text-4xl);
    color: var(--color-ink);
    margin-top: var(--space-3);
    max-width: 16ch;
  }
  .p-hero-desc {
    margin-top: var(--space-4);
    color: var(--color-text);
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    max-width: var(--measure-narrow);
  }
  .p-cta { margin-top: var(--space-5); display: flex; flex-wrap: wrap; gap: var(--space-3); }

  .p-hero-card {
    display: flex; align-items: flex-start; gap: var(--space-3);
    background: var(--color-green-tint);
    border: 1px solid var(--border-green-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
  }
  .p-hero-ic {
    display: inline-flex; height: 2.5rem; width: 2.5rem; flex: none; align-items: center;
    justify-content: center; border-radius: var(--radius-md);
    background: var(--surface); color: var(--color-green-strong);
  }
  .p-hero-card-t { margin-top: var(--space-4); color: var(--color-text); line-height: var(--leading-normal); font-size: var(--text-base); }

  /* Seções — ritmo claro/alternado */
  .p-sec { padding-block: var(--section-y); }
  .p-sec--white { background: var(--surface); }
  .p-sec--paper { background: var(--surface-subtle); }
  .p-sec--navy { background: var(--surface-strong); color: var(--color-text-on-dark); }
  .p-sec--navy :where(h2) { color: #fff; }
  .p-lead { margin-top: var(--space-4); color: var(--color-text); font-size: var(--text-md); line-height: var(--leading-relaxed); max-width: var(--measure); }

  .check-grid { list-style: none; padding: 0; margin: var(--space-6) 0 0; display: grid; gap: var(--space-4); grid-template-columns: 1fr; }
  @media (min-width: 720px) { .check-grid { grid-template-columns: repeat(2, 1fr); } }
  .check-grid--single { grid-template-columns: 1fr; }
  .check-grid li { display: flex; gap: var(--space-3); align-items: flex-start; color: var(--color-text); line-height: var(--leading-normal); }
  .ck { color: var(--color-green-strong); flex: none; margin-top: 3px; }

  .chip-grid { list-style: none; padding: 0; margin: var(--space-6) 0 0; display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .chip-grid li {
    background: var(--surface); border: 1px solid var(--border-subtle); border-radius: var(--radius-pill);
    padding: 0.55rem 1.05rem; font-size: var(--text-sm); color: var(--color-text);
  }

  .risk-grid { list-style: none; padding: 0; margin: var(--space-6) 0 0; display: grid; gap: var(--space-4); grid-template-columns: 1fr; }
  @media (min-width: 720px) { .risk-grid { grid-template-columns: repeat(2, 1fr); } }
  .risk-grid li {
    display: flex; gap: var(--space-3); align-items: flex-start; background: var(--surface);
    border: 1px solid var(--border-subtle); border-radius: var(--radius-md); padding: var(--space-4) var(--space-5);
    color: var(--color-text); font-size: var(--text-sm); line-height: var(--leading-normal);
  }
  .rk { color: var(--color-warn); flex: none; margin-top: 2px; }

  /* CTA intermediário — realce de ação suave */
  .p-cta-mid { background: var(--color-green-tint); border-block: 1px solid var(--border-green-subtle); }
  .cta-mid-inner { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: var(--space-4); padding-block: var(--space-6); }
  .cta-mid-inner p { font-family: var(--font-display); font-size: var(--text-lg); color: var(--color-ink); }

  .sub-grid { list-style: none; padding: 0; margin: var(--space-6) 0 0; display: grid; gap: var(--space-4); grid-template-columns: 1fr; }
  @media (min-width: 860px) { .sub-grid { grid-template-columns: repeat(2, 1fr); } }
  .sub-grid a {
    display: grid; grid-template-columns: 1fr auto; align-items: start; gap: var(--space-2) var(--space-3);
    padding: var(--space-5); background: var(--surface); border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md); text-decoration: none;
    transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .sub-grid a:hover { border-color: var(--border-strong); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .sub-grid strong { color: var(--color-ink); font-weight: var(--weight-semibold); }
  .sub-grid span { grid-column: 1 / -1; color: var(--color-text-muted); font-size: var(--text-sm); line-height: var(--leading-normal); }
  .sg-arrow { color: var(--color-green-strong); }

  /* Banda "Guia completo" — superfície distinta e clara (não escura) */
  .p-guide-band { background: var(--surface-muted); border-block: 1px solid var(--border-subtle); }
  .p-guide-band :where(h2) { color: var(--color-ink); }
  .p-guide-band .p-lead { color: var(--color-text); }
  .guide-inner { display: grid; gap: var(--space-6); align-items: center; grid-template-columns: 1fr; }
  @media (min-width: 860px) { .guide-inner { grid-template-columns: 1.6fr auto; gap: var(--space-10); } }

  .two-col { display: grid; gap: var(--space-10); grid-template-columns: 1fr; }
  @media (min-width: 900px) { .two-col { grid-template-columns: 1fr 1fr; gap: var(--space-16); } }
  .steps { list-style: none; padding: 0; margin: var(--space-6) 0 0; display: flex; flex-direction: column; gap: var(--space-5); }
  .steps li { display: flex; gap: var(--space-4); }
  .s-n { font-family: var(--font-display); font-weight: var(--weight-semibold); color: var(--color-green-strong); font-size: var(--text-lg); flex: none; width: 1.75rem; }
  .steps strong { color: var(--color-ink); font-weight: var(--weight-semibold); }
  .steps p { margin-top: 2px; color: var(--color-text-muted); font-size: var(--text-sm); line-height: var(--leading-normal); }

  .rel-grid { list-style: none; padding: 0; margin: var(--space-6) 0 0; display: grid; gap: var(--space-3); grid-template-columns: 1fr; }
  @media (min-width: 720px) { .rel-grid { grid-template-columns: repeat(2, 1fr); } }
  .rel-grid a {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-4);
    padding: var(--space-4) var(--space-5); background: var(--surface); border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md); text-decoration: none; color: var(--color-ink); font-weight: var(--weight-medium);
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .rel-grid a:hover { border-color: var(--color-green); color: var(--color-green-strong); }

  /* CTA final — faixa institucional escura (a única forte da página) */
  .cta-inner { display: grid; gap: var(--space-6); grid-template-columns: 1fr; align-items: center; }
  @media (min-width: 900px) { .cta-inner { grid-template-columns: 1.6fr 1fr; gap: var(--space-10); } }
  .cta-title { color: #fff; font-size: var(--text-2xl); line-height: var(--leading-snug); max-width: 22ch; }
  .cta-text { margin-top: var(--space-4); color: var(--color-text-on-dark-muted); line-height: var(--leading-normal); max-width: var(--measure-narrow); }
  .cta-actions { display: flex; flex-wrap: wrap; gap: var(--space-3); }
</style>
