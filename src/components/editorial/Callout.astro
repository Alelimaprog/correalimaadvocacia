---
/**
 * Callout — bloco de destaque editorial (Nota / Atenção / Importante).
 * Reutilizável em guias e artigos. Sem conteúdo jurídico embutido: o texto vem
 * do slot. Acessível (role e cor + ícone, não só cor).
 * Uso: <Callout tipo="atencao" titulo="Prazo">Conteúdo…</Callout>
 */
import Icon from '@/components/Icon.astro';
interface Props { tipo?: 'nota' | 'atencao' | 'importante'; titulo?: string; }
const { tipo = 'nota', titulo } = Astro.props;
const cfg = {
  nota: { icon: 'message', label: 'Nota' },
  atencao: { icon: 'shield', label: 'Atenção' },
  importante: { icon: 'scale', label: 'Importante' },
}[tipo];
---
<aside class:list={['callout', `callout--${tipo}`]} role="note">
  <span class="callout-ic"><Icon name={cfg.icon} size={18} /></span>
  <div class="callout-body">
    <p class="callout-title">{titulo ?? cfg.label}</p>
    <div class="callout-content"><slot /></div>
  </div>
</aside>

<style>
  .callout { display: flex; gap: var(--space-3); border: 1px solid var(--color-border); border-left-width: 3px; border-radius: var(--radius-md); padding: var(--space-4) var(--space-5); background: var(--surface); margin: var(--space-5) 0; }
  .callout-ic { flex: none; display: inline-flex; color: var(--color-green-strong); }
  .callout-title { font-family: var(--font-display); font-weight: var(--weight-bold); color: var(--color-ink); font-size: var(--text-sm); }
  .callout-content { margin-top: 0.25rem; color: var(--color-text); font-size: var(--text-sm); line-height: var(--leading-relaxed); }
  .callout--nota { border-left-color: var(--color-green); }
  .callout--atencao { border-left-color: var(--color-warning); background: color-mix(in srgb, var(--color-warning) 5%, var(--surface)); }
  .callout--atencao .callout-ic { color: var(--color-warning); }
  .callout--importante { border-left-color: var(--color-green-strong); background: var(--color-green-tint); }
</style>
