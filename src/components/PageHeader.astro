---
/**
 * PageHeader — bloco de topo das páginas internas: breadcrumb opcional,
 * eyebrow opcional, H1 e descrição opcional. Estrutura reutilizável para
 * áreas, guias, institucionais etc. (o conteúdo real virá nas fases de migração).
 */
import Container from '@/components/Container.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import type { Crumb } from '@/components/Breadcrumb.astro';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  breadcrumb?: Crumb[];
  class?: string;
}
const { title, description, eyebrow, breadcrumb, class: cls } = Astro.props;
---

<div class:list={['page-header', cls]}>
  <Container>
    {breadcrumb && breadcrumb.length > 0 && <Breadcrumb items={breadcrumb} class="ph-crumb" />}
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h1>{title}</h1>
    {description && <p class="ph-desc">{description}</p>}
    <slot />
  </Container>
</div>

<style>
  .page-header {
    padding-block: clamp(1.5rem, 1.1rem + 1.6vw, 2.5rem);
    border-bottom: 1px solid var(--color-border);
  }
  .ph-crumb {
    margin-bottom: 1rem;
  }
  .eyebrow {
    display: inline-block;
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-green-strong);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .ph-desc {
    margin-top: 1rem;
    max-width: 46rem;
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }
</style>
