---
/**
 * Logo — link para a home com o logotipo. Componente único usado no header e no
 * rodapé (evita HTML duplicado). Proporção do arquivo vetorial: ~371x100 (3,71:1).
 * variant 'dark' usa o logo para fundo escuro (navy) — padrão de header/footer.
 */
import { site } from '@/lib/site.config';

interface Props {
  variant?: 'dark' | 'light';
  class?: string;
  loading?: 'eager' | 'lazy';
}
const { variant = 'dark', class: cls, loading = 'eager' } = Astro.props;
const src = variant === 'dark' ? '/brand/logo-dark-bg.svg' : '/brand/logo-light-bg.svg';
---

<a class:list={['logo', cls]} href="/" aria-label={`${site.name} — página inicial`}>
  <img src={src} alt={site.name} width="371" height="100" decoding="async" loading={loading} />
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
  }
  .logo img {
    height: 2.25rem; /* 36px */
    width: auto;
  }
  @media (min-width: 768px) {
    .logo img {
      height: 2.75rem; /* 44px */
    }
  }
</style>
