---
/**
 * HomeContent — Home reformulada para conversão (reconhecimento → compreensão →
 * confiança → redução de incerteza → contato). Seções: faixa de confiança,
 * entrada por problema, áreas de atuação, perfis atendidos, como funciona,
 * forma de atuação, conteúdos, FAQ (2 colunas) e CTA. Sem números inventados.
 */
import { whatsappHref } from '@/lib/site.config';
import { nucleos, getNucleo } from '@/lib/nucleos';
import { site } from '@/lib/site.config';
import Icon from '@/components/Icon.astro';
import { homeFaq as faq } from '@/lib/home-faq';

const N = (s: string) => getNucleo(s)!.href;

const problems = [
  { t: 'Tenho valores a receber de uma empresa ou pessoa', d: 'Cobrança, execução e localização de patrimônio do devedor.', href: N('recuperacao-de-credito') },
  { t: 'O condomínio possui cotas em atraso', d: 'Cobrança de cotas condominiais e negociação de acordos.', href: N('cobranca-condominial') },
  { t: 'Meu imóvel possui restrição ambiental', d: 'Análise de APP, ocupação, regularização e riscos ambientais.', href: N('direito-ambiental') },
  { t: 'Recebi uma multa ou embargo ambiental', d: 'Defesa administrativa ou judicial diante da autuação.', href: N('direito-ambiental') },
  { t: 'Minha mercadoria foi retida ou autuada', d: 'Atuação em retenção, exigências, multas e perdimento.', href: N('direito-aduaneiro-tributario') },
  { t: 'Preciso usar no Brasil uma decisão estrangeira', d: 'Homologação de decisões e documentos produzidos no exterior.', href: N('direito-internacional') },
  { t: 'Preciso realizar um inventário', d: 'Inventário, partilha e bens ou herdeiros no exterior.', href: N('inventario-e-patrimonio') },
];

const perfis = [
  { icon: 'coins', t: 'Empresas e credores', d: 'Cobrança de valores, execução de títulos e questões ambientais, aduaneiras ou regulatórias.' },
  { icon: 'building', t: 'Condomínios e administradoras', d: 'Recuperação de cotas, negociação de acordos e controle jurídico da inadimplência.' },
  { icon: 'home', t: 'Proprietários e adquirentes de imóveis', d: 'Questões ambientais, patrimoniais, sucessórias e de regularidade do imóvel.' },
  { icon: 'package', t: 'Importadores e comércio exterior', d: 'Retenção de mercadorias, autuações, multas, perdimento e tributação na importação.' },
  { icon: 'globe', t: 'Pessoas com demandas internacionais', d: 'Decisões estrangeiras, documentos, patrimônio, família ou sucessão entre países.' },
];

const steps = [
  { n: '01', t: 'Entendimento inicial', d: 'Conhecemos a situação, o objetivo do cliente e os principais acontecimentos relacionados ao problema.' },
  { n: '02', t: 'Análise dos documentos e riscos', d: 'Examinamos os documentos disponíveis e identificamos os pontos que precisam de atenção.' },
  { n: '03', t: 'Definição das medidas possíveis', d: 'Apresentamos as alternativas adequadas — negociação, procedimento administrativo ou processo judicial.' },
  { n: '04', t: 'Condução e acompanhamento', d: 'Após a contratação, o escritório conduz as medidas definidas e informa os acontecimentos relevantes.' },
];

const diferenciais = [
  { icon: 'search', t: 'Análise antes da adoção de medidas', d: 'Os documentos, riscos e objetivos são examinados antes de definir o caminho jurídico.' },
  { icon: 'scale', t: 'Estratégia proporcional ao problema', d: 'A medida considera urgência, custos, riscos, patrimônio envolvido e possibilidade prática de resultado.' },
  { icon: 'shield', t: 'Visão jurídica e patrimonial integrada', d: 'A análise considera o processo e também os efeitos sobre bens, créditos, imóveis e atividade empresarial.' },
  { icon: 'route', t: 'Atuação preventiva e contenciosa', d: 'Atuação tanto na prevenção de conflitos quanto em procedimentos administrativos e judiciais.' },
  { icon: 'message', t: 'Comunicação objetiva', d: 'Etapas, alternativas e acontecimentos relevantes apresentados de maneira compreensível.' },
  { icon: 'globe', t: 'Casos nacionais e internacionais', d: 'Demandas no Brasil e situações envolvendo bens, pessoas, documentos ou decisões estrangeiras.' },
];

const conteudos = [
  { tag: 'Guia', t: 'Cobrança, Execução e Recuperação de Crédito Empresarial', d: 'Entenda os documentos necessários e as medidas que podem ser usadas para buscar a recuperação do crédito.', href: '/guias/cobranca-execucao-e-recuperacao-de-credito-empresarial/' },
  { tag: 'Guia', t: 'Homologação de Sentença Estrangeira no Brasil', d: 'Saiba quando uma decisão estrangeira precisa ser homologada e como o procedimento é realizado.', href: '/guias/homologacao-de-sentenca-estrangeira-no-brasil/' },
  { tag: 'Guia', t: 'Recuperação Judicial, Falência e Medidas do Credor', d: 'Conheça os cuidados do credor diante da recuperação judicial ou da falência de uma empresa devedora.', href: '/guias/recuperacao-judicial-falencia-e-medidas-do-credor/' },
];

const trust = [
  { icon: 'scale', t: site.attorney.oab.replace('OAB/SP ', 'OAB/SP ') },
  { icon: 'map-pin', t: 'Atendimento nacional e online' },
  { icon: 'users', t: 'Atuação para pessoas e empresas' },
  { icon: 'globe', t: 'Demandas no Brasil e no exterior' },
];
---

<!-- Faixa de confiança -->
<section class="hs hs--white trust-band">
  <div class="hc">
    <ul class="trust-grid">
      {trust.map((t) => (
        <li><span class="trust-ic"><Icon name={t.icon} size={18} /></span>{t.t}</li>
      ))}
    </ul>
  </div>
</section>

<!-- Entrada por problema -->
<section class="hs hs--cream">
  <div class="hc">
    <p class="eyebrow"><span class="dot"></span>Como podemos ajudar</p>
    <h2 class="sec-h2">Qual situação levou você a procurar um advogado?</h2>
    <p class="sec-intro">Selecione a situação mais próxima da sua para entender como o escritório pode atuar.</p>
    <ul class="problem-grid">
      {problems.map((p) => (
        <li>
          <a href={p.href}>
            <span class="pg-body">
              <span class="pg-t">{p.t}</span>
              <span class="pg-d">{p.d}</span>
            </span>
            <span class="pg-arrow"><Icon name="arrow-right" size={18} /></span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<!-- Áreas de atuação -->
<section class="hs hs--white">
  <div class="hc">
    <p class="eyebrow"><span class="dot"></span>Áreas de atuação</p>
    <h2 class="sec-h2">Atuação jurídica organizada por áreas complementares</h2>
    <p class="sec-intro">O escritório concentra sua atuação em questões que envolvem patrimônio, crédito, imóveis, atividade empresarial, importações e relações internacionais.</p>
    <div class="nucleo-grid">
      {nucleos.map((n) => (
        <a class="ncard" href={n.href}>
          <span class="ncard-ic"><Icon name={n.icon} size={24} /></span>
          <h3 class="ncard-t">{n.label}</h3>
          <p class="ncard-d">{n.short}</p>
          <span class="ncard-more">Conhecer esta área <Icon name="arrow-right" size={15} /></span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Perfis atendidos -->
<section class="hs hs--ornament">
  <div class="hc">
    <p class="eyebrow"><span class="dot"></span>Perfis atendidos</p>
    <h2 class="sec-h2">Atuação direcionada ao contexto de cada cliente</h2>
    <p class="sec-intro">Os riscos, documentos e medidas possíveis variam conforme o perfil do cliente e a natureza da demanda.</p>
    <div class="perfil-grid">
      {perfis.map((p) => (
        <article class="perfil">
          <span class="perfil-ic"><Icon name={p.icon} size={22} /></span>
          <div>
            <h3 class="perfil-t">{p.t}</h3>
            <p class="perfil-d">{p.d}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Como funciona -->
<section class="hs hs--warm">
  <div class="hc">
    <p class="eyebrow"><span class="dot"></span>Como funciona</p>
    <h2 class="sec-h2">Do primeiro contato à definição da estratégia</h2>
    <div class="step-grid">
      {steps.map((s) => (
        <article class="step">
          <span class="step-n">{s.n}</span>
          <h3 class="step-t">{s.t}</h3>
          <p class="step-d">{s.d}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Forma de atuação (diferenciais) -->
<section class="hs hs--white">
  <div class="hc">
    <p class="eyebrow"><span class="dot"></span>Forma de atuação</p>
    <h2 class="sec-h2">Critério técnico, estratégia e clareza na condução do caso</h2>
    <div class="dif-grid">
      {diferenciais.map((d) => (
        <article class="dif">
          <span class="dif-ic"><Icon name={d.icon} size={22} /></span>
          <div>
            <h3 class="dif-t">{d.t}</h3>
            <p class="dif-d">{d.d}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Conteúdos -->
<section class="hs hs--warm">
  <div class="hc">
    <p class="eyebrow"><span class="dot"></span>Conteúdos</p>
    <h2 class="sec-h2">Materiais para entender melhor o seu caso</h2>
    <div class="cont-grid">
      {conteudos.map((c) => (
        <a class="cont" href={c.href}>
          <span class="cont-tag">{c.tag}</span>
          <h3 class="cont-t">{c.t}</h3>
          <p class="cont-d">{c.d}</p>
          <span class="cont-more">Ler o guia <Icon name="arrow-right" size={15} /></span>
        </a>
      ))}
    </div>
    <a class="viewall" href="/guias/">Ver todos os conteúdos <Icon name="arrow-right" size={15} /></a>
  </div>
</section>

<!-- FAQ — duas colunas -->
<section class="hs hs--faq">
  <div class="hc faq-split">
    <div class="faq-aside">
      <p class="eyebrow"><span class="dot"></span>Perguntas frequentes</p>
      <h2 class="sec-h2">Antes de entrar em contato</h2>
      <p class="sec-intro">Respostas objetivas para dúvidas comuns sobre cobranças, condomínios, questões ambientais, importações, decisões estrangeiras e inventários. As respostas têm caráter informativo e não substituem a análise individual do caso.</p>
      <div class="faq-cta">
        <p class="faq-cta-t">Não encontrou a sua dúvida?</p>
        <p class="faq-cta-d">Apresente brevemente a situação para que o escritório possa identificar a área jurídica relacionada.</p>
        <a class="btn btn--primary" href="/contato/">Falar com o escritório</a>
      </div>
    </div>
    <div class="faq-list">
      {faq.map((f) => (
        <details class="faq-item">
          <summary>
            <span>{f.q}</span>
            <span class="faq-mark" aria-hidden="true"></span>
          </summary>
          <div class="faq-a"><p>{f.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- CTA antes do formulário -->
<section class="hs hs--cta-green">
  <div class="hc cta-final">
    <div>
      <p class="eyebrow eyebrow--on-dark"><span class="dot"></span>Fale com o escritório</p>
      <h2 class="cta-title">Apresente a situação e entenda quais podem ser os próximos passos</h2>
      <p class="cta-text">Envie uma breve descrição do problema e indique os documentos disponíveis para iniciar o atendimento.</p>
    </div>
    <div class="cta-actions">
      <a class="btn btn--on-green btn--lg" href="/contato/">Solicitar atendimento</a>
      <a class="btn btn--ghost-light btn--lg" href={whatsappHref} target="_blank" rel="noopener noreferrer">Falar pelo WhatsApp</a>
    </div>
  </div>
</section>

<style>
  .hs { padding-block: var(--section-y); }
  .hs--warm { background: var(--surface-warm); }
  .hs--cream { background: var(--surface-cream); }
  .hs--white { background: var(--surface); }
  .hc { width: 100%; max-width: var(--container-max); margin-inline: auto; padding-inline: var(--container-pad); }

  .eyebrow { font-family: var(--font-body); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--tracking-eyebrow); color: var(--color-green-strong); font-weight: var(--weight-semibold); display: inline-flex; align-items: center; gap: 0.5rem; }
  .eyebrow .dot { height: 6px; width: 6px; border-radius: var(--radius-pill); background: var(--color-green); }
  .eyebrow--on-dark { color: #b9ecc9; }
  .eyebrow--on-dark .dot { background: #b9ecc9; }
  .sec-h2 { font-family: var(--font-display); font-weight: var(--weight-bold); font-size: var(--text-3xl); color: var(--color-ink); line-height: var(--leading-snug); margin-top: var(--space-3); max-width: 26ch; text-wrap: balance; }
  .sec-intro { margin-top: var(--space-3); max-width: var(--measure); color: var(--color-text-muted); font-size: var(--text-md); line-height: var(--leading-normal); }

  /* Faixa de confiança */
  .trust-band { padding-block: var(--space-5); border-bottom: 1px solid var(--border-subtle); }
  .trust-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: var(--space-3) var(--space-6); }
  @media (min-width: 620px) { .trust-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 980px) { .trust-grid { grid-template-columns: repeat(4, 1fr); } }
  .trust-grid li { display: inline-flex; align-items: center; gap: var(--space-3); color: var(--color-ink); font-size: var(--text-sm); font-weight: var(--weight-medium); }
  .trust-ic { flex: none; display: inline-flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; border-radius: var(--radius-md); background: var(--color-green-tint); color: var(--color-green-strong); }

  /* Entrada por problema */
  .problem-grid { list-style: none; margin: var(--space-6) 0 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: var(--space-3); }
  @media (min-width: 760px) { .problem-grid { grid-template-columns: 1fr 1fr; } }
  .problem-grid a { display: flex; align-items: center; gap: var(--space-4); background: var(--surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.05rem 1.25rem; text-decoration: none; transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease); }
  .problem-grid a:hover { border-color: transparent; box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .pg-body { display: flex; flex-direction: column; gap: 0.15rem; flex: 1; }
  .pg-t { color: var(--color-ink); font-weight: var(--weight-semibold); font-size: var(--text-md); line-height: var(--leading-snug); }
  .pg-d { color: var(--color-text-muted); font-size: var(--text-sm); line-height: var(--leading-normal); }
  .pg-arrow { display: inline-flex; color: var(--color-green-strong); flex: none; transition: transform var(--dur) var(--ease); }
  .problem-grid a:hover .pg-arrow { transform: translateX(3px); }

  /* Cards de núcleos */
  .nucleo-grid { margin-top: var(--space-6); display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 640px) { .nucleo-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 980px) { .nucleo-grid { grid-template-columns: repeat(3, 1fr); } }
  .ncard { display: flex; flex-direction: column; background: var(--surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; text-decoration: none; transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease); }
  .ncard:hover { border-color: transparent; box-shadow: var(--shadow-md); transform: translateY(-3px); }
  .ncard-ic { display: inline-flex; height: 3rem; width: 3rem; align-items: center; justify-content: center; border-radius: var(--radius-md); background: var(--color-green-tint); color: var(--color-green-strong); }
  .ncard-t { margin-top: var(--space-4); font-family: var(--font-display); font-size: var(--text-lg); color: var(--color-ink); }
  .ncard-d { margin-top: var(--space-2); color: var(--color-text-muted); font-size: var(--text-sm); line-height: var(--leading-normal); flex: 1; }
  .ncard-more { margin-top: var(--space-4); display: inline-flex; align-items: center; gap: 0.35rem; color: var(--color-green-strong); font-weight: var(--weight-semibold); font-size: var(--text-sm); }
  .ncard:hover .ncard-more { color: var(--color-green); }

  /* Perfis atendidos */
  .perfil-grid { margin-top: var(--space-6); display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 700px) { .perfil-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1040px) { .perfil-grid { grid-template-columns: repeat(3, 1fr); } }
  .perfil { display: flex; gap: var(--space-4); background: var(--surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.25rem; }
  .perfil-ic { flex: none; display: inline-flex; height: 2.75rem; width: 2.75rem; align-items: center; justify-content: center; border-radius: var(--radius-md); background: var(--color-green-tint); color: var(--color-green-strong); }
  .perfil-t { font-family: var(--font-display); font-size: var(--text-md); color: var(--color-ink); line-height: var(--leading-snug); }
  .perfil-d { margin-top: 0.35rem; color: var(--color-text-muted); font-size: var(--text-sm); line-height: var(--leading-normal); }

  /* Como funciona */
  .step-grid { margin-top: var(--space-6); display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 640px) { .step-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1040px) { .step-grid { grid-template-columns: repeat(4, 1fr); } }
  .step { background: var(--surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; }
  .step-n { font-family: var(--font-display); font-weight: var(--weight-bold); font-size: 2rem; color: var(--color-green); line-height: 1; }
  .step-t { margin-top: var(--space-3); font-family: var(--font-display); font-size: var(--text-lg); color: var(--color-ink); line-height: var(--leading-snug); }
  .step-d { margin-top: var(--space-2); color: var(--color-text-muted); font-size: var(--text-sm); line-height: var(--leading-normal); }

  /* Forma de atuação */
  .dif-grid { margin-top: var(--space-6); display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 700px) { .dif-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1040px) { .dif-grid { grid-template-columns: repeat(3, 1fr); } }
  .dif { display: flex; gap: var(--space-4); background: var(--surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.25rem; }
  .dif-ic { flex: none; display: inline-flex; height: 2.75rem; width: 2.75rem; align-items: center; justify-content: center; border-radius: var(--radius-md); background: var(--color-green-tint); color: var(--color-green-strong); }
  .dif-t { font-family: var(--font-display); font-size: var(--text-md); color: var(--color-ink); line-height: var(--leading-snug); }
  .dif-d { margin-top: 0.35rem; color: var(--color-text-muted); font-size: var(--text-sm); line-height: var(--leading-normal); }

  /* Conteúdos */
  .cont-grid { margin-top: var(--space-6); display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 760px) { .cont-grid { grid-template-columns: repeat(3, 1fr); } }
  .cont { display: flex; flex-direction: column; background: var(--surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; text-decoration: none; transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease); }
  .cont:hover { border-color: transparent; box-shadow: var(--shadow-md); transform: translateY(-3px); }
  .cont-tag { align-self: flex-start; font-size: var(--text-xs); font-weight: var(--weight-semibold); text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-green-strong); background: var(--color-green-tint); padding: 0.2rem 0.6rem; border-radius: var(--radius-pill); }
  .cont-t { margin-top: var(--space-3); font-family: var(--font-display); font-size: var(--text-md); color: var(--color-ink); line-height: var(--leading-snug); }
  .cont-d { margin-top: var(--space-2); color: var(--color-text-muted); font-size: var(--text-sm); line-height: var(--leading-normal); flex: 1; }
  .cont-more { margin-top: var(--space-4); display: inline-flex; align-items: center; gap: 0.35rem; color: var(--color-green-strong); font-weight: var(--weight-semibold); font-size: var(--text-sm); }
  .viewall { margin-top: var(--space-5); display: inline-flex; align-items: center; gap: 0.4rem; color: var(--color-green-strong); font-weight: var(--weight-semibold); font-size: var(--text-sm); text-decoration: none; }
  .viewall:hover { color: var(--color-green); }

  /* FAQ — duas colunas */
  .hs--faq { position: relative; overflow: hidden; background: #f5faf7; }
  .hs--faq::before { content: ''; position: absolute; inset: 0; pointer-events: none; background: radial-gradient(60% 55% at 15% 0%, rgba(0,168,90,0.08), transparent 70%); }
  .faq-split { position: relative; display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
  @media (min-width: 900px) { .faq-split { grid-template-columns: 35% 1fr; gap: var(--space-10); align-items: start; } }
  .faq-cta { margin-top: var(--space-5); background: var(--surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.25rem; box-shadow: var(--shadow-sm); }
  .faq-cta-t { font-family: var(--font-display); font-weight: var(--weight-bold); color: var(--color-ink); font-size: var(--text-md); }
  .faq-cta-d { margin: 0.35rem 0 var(--space-4); color: var(--color-text-muted); font-size: var(--text-sm); line-height: var(--leading-normal); }
  .faq-list { display: flex; flex-direction: column; gap: var(--space-3); }
