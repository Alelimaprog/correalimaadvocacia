---
/**
 * Icon — conjunto único de ícones (SVG outline, sóbrio e discreto) reutilizado
 * em toda a interface. Evita SVGs duplicados espalhados pelos componentes.
 * Uso: <Icon name="coins" class="..." />
 */
interface Props {
  name: string;
  class?: string;
  size?: number;
}
const { name, class: className, size = 24 } = Astro.props;

const ICONS: Record<string, string> = {
  // Núcleos
  coins: '<circle cx="8" cy="8" r="4.5"/><path d="M11.5 5.6A4.5 4.5 0 1 1 14 15.9"/><path d="M6 8h4M8 6v4"/>',
  building: '<rect x="4" y="3" width="10" height="18" rx="1"/><path d="M8 7h2M8 11h2M8 15h2"/><path d="M14 9h5v12h-5"/><path d="M4 21h16"/>',
  leaf: '<path d="M5 20c0-8 5-13 15-13 0 10-5 14-12 14-3 0-3-1-3-1z"/><path d="M9 16c1.5-3 3.5-5 7-6.5"/>',
  package: '<path d="M12 3 4 7v10l8 4 8-4V7z"/><path d="M4 7l8 4 8-4"/><path d="M12 11v10"/><path d="M8 5l8 4"/>',
  globe: '<circle cx="12" cy="12" r="8.5"/><path d="M3.5 12h17M12 3.5c2.5 2.4 3.8 5.3 3.8 8.5s-1.3 6.1-3.8 8.5c-2.5-2.4-3.8-5.3-3.8-8.5S9.5 5.9 12 3.5z"/>',
  home: '<path d="M4 11.5 12 4l8 7.5"/><path d="M6 10v9.5h12V10"/><path d="M10 19.5V14h4v5.5"/>',
  // Utilitários
  check: '<circle cx="12" cy="12" r="9"/><path d="M8.2 12.3l2.5 2.5 5-5.2"/>',
  'arrow-right': '<path d="M5 12h13.5M13 6.5 19 12l-6 5.5"/>',
  search: '<circle cx="11" cy="11" r="7"/><path d="M20 20l-4-4"/>',
  scale: '<path d="M12 4v16M7 20h10"/><path d="M6 7h12M6 7 3.5 13a3 3 0 0 0 5 0zM18 7l2.5 6a3 3 0 0 1-5 0z"/><path d="M12 4l-6 3M12 4l6 3"/>',
  file: '<path d="M7 3h7l4 4v14H7z"/><path d="M14 3v4h4"/><path d="M9.5 12h6M9.5 15.5h6M9.5 8.5h2"/>',
  users: '<circle cx="8.5" cy="8" r="2.6"/><circle cx="16" cy="9" r="2.1"/><path d="M3.5 19.5c.5-3.2 2.4-5 5-5s4.5 1.8 5 5"/><path d="M14.3 14.8c1.9.2 3.3 1.8 3.7 4.2"/>',
  shield: '<path d="M12 3.5 5 6v6c0 4.2 2.9 7.3 7 8.5 4.1-1.2 7-4.3 7-8.5V6z"/><path d="M9 12l2 2 4-4.2"/>',
  clock: '<circle cx="12" cy="12" r="8.5"/><path d="M12 7.5V12l3 2"/>',
  route: '<circle cx="6" cy="18" r="2.2"/><circle cx="18" cy="6" r="2.2"/><path d="M8 18h6a4 4 0 0 0 0-8H9a4 4 0 0 1 0-8"/>',
  message: '<path d="M4 5h16v11H8l-4 4z"/><path d="M8 9h8M8 12h5"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3.5 6.5 8.5 6 8.5-6"/>',
  'map-pin': '<path d="M12 21s6.5-5.5 6.5-10.5A6.5 6.5 0 0 0 5.5 10.5C5.5 15.5 12 21 12 21z"/><circle cx="12" cy="10.4" r="2.4"/>',
  phone: '<path d="M6 3h3l1.5 5-2 1.5a11 11 0 0 0 5 5l1.5-2 5 1.5v3a2 2 0 0 1-2 2A16 16 0 0 1 4 5a2 2 0 0 1 2-2z"/>',
  whatsapp: '<path d="M17.6 6.4A8.9 8.9 0 0 0 12 4a8.94 8.94 0 0 0-7.75 13.4L3 21l3.7-1.2A8.94 8.94 0 0 0 12 21a8.94 8.94 0 0 0 6.3-15.6zM12 19.3a7.3 7.3 0 0 1-3.73-1.02l-.27-.16-2.2.7.72-2.14-.18-.28A7.32 7.32 0 1 1 19.3 12 7.32 7.32 0 0 1 12 19.3z"/><path d="M15.1 13.6c-.2-.1-1.2-.6-1.4-.65-.2-.08-.34-.1-.48.1s-.55.65-.67.78-.25.15-.46.05a5.87 5.87 0 0 1-1.73-1.07 6.5 6.5 0 0 1-1.2-1.49c-.13-.2 0-.32.1-.42.1-.1.2-.25.3-.37a1.4 1.4 0 0 0 .2-.34.38.38 0 0 0 0-.36c-.05-.1-.48-1.15-.66-1.58s-.35-.36-.48-.37h-.4a.79.79 0 0 0-.57.27 2.4 2.4 0 0 0-.75 1.78 4.17 4.17 0 0 0 .87 2.2 9.5 9.5 0 0 0 3.63 3.2c1.32.57 1.85.62 2.5.52.4-.06 1.2-.5 1.38-.97s.18-.88.13-.97-.18-.14-.38-.24z"/>',
};
const inner = ICONS[name] ?? '';
const stroke = name === 'whatsapp';
---
<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={stroke ? 'currentColor' : 'none'}
  stroke={stroke ? 'none' : 'currentColor'}
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={inner}
/>
