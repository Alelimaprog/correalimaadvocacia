---
/**
 * SubPage — layout das subpáginas de alta intenção (Sprint 2), sob cada núcleo.
 * Recebe `nucleo` e `sub` e monta a página a partir de subtopics.ts + nucleos.ts:
 * SEO exclusivo, JSON-LD (BreadcrumbList + Service + FAQPage), breadcrumb, hero,
 * explicação do problema, situações, atuação, riscos, CTA intermediário, FAQ,
 * serviços/conteúdos relacionados e CTA final. Linkagem interna forte.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import JsonLd from '@/components/JsonLd.astro';
import Icon from '@/components/Icon.astro';
import { site, whatsappHrefForPath } from '@/lib/site.config';
import { getNucleo } from '@/lib/nucleos';
import { getSubtopic, getSubtopicsByNucleo } from '@/lib/subtopics';
import type { PageHead } from '@/lib/institucional';

interface Props { nucleo: string; sub: string }
const { nucleo, sub } = Astro.props;
const n = getNucleo(nucleo)!;
const s = getSubtopic(nucleo, sub)!;
const waHref = whatsappHrefForPath(`/areas-de-atuacao/${nucleo}/`); // ETAPA 18
const siblings = getSubtopicsByNucleo(nucleo).filter((x) => x.slug !== sub);

const url = `${site.url}/areas-de-atuacao/${nucleo}/${sub}/`;
const title = `${s.seoTitle} | ${site.name}`;
const ogImage = `${site.url}${site.ogImage}`;

const head: PageHead = {
  title,
  description: s.seoDescription,
  canonical: url,
  robots: 'index, follow',
  og: { title, description: s.seoDescription, url, type: 'article', site_name: site.name, locale: site.locale, image: ogImage },
  twitter: { card: 'summary_large_image', title, description: s.seoDescription, image: ogImage },
};

const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${site.url}/` },
      { '@type': 'ListItem', position: 2, name: 'Áreas de Atuação', item: `${site.url}/areas-de-atuacao/` },
      { '@type': 'ListItem', position: 3, name: n.label, item: `${site.url}${n.href}` },
      { '@type': 'ListItem', position: 4, name: s.label, item: url },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: s.label,
    name: s.seoTitle,
    description: s.seoDescription,
    areaServed: 'BR',
    url,
    provider: { '@type': 'LegalService', name: site.name, url: `${site.url}/`, email: site.contact.email, telephone: site.contact.whatsapp.display },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: s.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---

<BaseLayout head={head}>
  <Fragment slot="jsonld">{jsonld.map((schema) => <JsonLd schema={schema} />)}</Fragment>

  <main id="conteudo-principal" class="sub">
    <section class="s-hero">
      <div class="wrap">
        <nav class="crumbs" aria-label="Você está em">
          <a href="/">Início</a><span>/</span>
          <a href="/areas-de-atuacao/">Áreas de Atuação</a><span>/</span>
          <a href={n.href}>{n.label}</a><span>/</span>
          <span>{s.label}</span>
        </nav>
        <p class="eyebrow"><span class="dot"></span>{n.label}</p>
        <h1>{s.h1}</h1>
        <p class="s-hero-desc">{s.heroDescription}</p>
        <div class="cta-row">
          <a class="btn btn--primary" href={waHref} target="_blank" rel="noopener noreferrer">Falar com um advogado</a>
          <a class="btn btn--secondary" href="/contato/">Solicitar análise inicial</a>
        </div>
      </div>
    </section>

    <section class="s-sec s-sec--white">
      <div class="wrap wrap--narrow">
        <h2>Entenda o problema</h2>
        <p class="lead">{s.problem}</p>
      </div>
    </section>

    <section class="s-sec s-sec--paper">
      <div class="wrap two-col">
        <div>
          <p class="eyebrow"><span class="dot"></span>Situações comuns</p>
          <h2>Quando procurar</h2>
          <ul class="check">
            {s.situations.map((i) => <li><Icon name="check" size={18} class="ck" /><span>{i}</span></li>)}
          </ul>
        </div>
        <div>
          <p class="eyebrow"><span class="dot"></span>Nossa atuação</p>
          <h2>Como atuamos</h2>
          <ul class="check">
            {s.atuacao.map((i) => <li><Icon name="arrow-right" size={17} class="ck" /><span>{i}</span></li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="s-sec s-sec--white">
      <div class="wrap">
        <p class="eyebrow"><span class="dot"></span>Riscos de não agir</p>
        <h2>Por que o tempo importa</h2>
        <ul class="risk-grid">
          {s.risks.map((r) => <li><Icon name="shield" size={18} class="rk" /><span>{r}</span></li>)}
        </ul>
      </div>
    </section>

    <!-- CTA intermediário -->
    <section class="s-cta-mid">
      <div class="wrap cta-mid-inner">
        <p>Quer saber como isso se aplica ao seu caso?</p>
        <a class="btn btn--primary" href="/contato/">Solicitar análise inicial</a>
      </div>
    </section>

    <section class="s-sec s-sec--paper">
      <div class="wrap wrap--narrow">
        <p class="eyebrow"><span class="dot"></span>Perguntas frequentes</p>
        <h2>Dúvidas comuns</h2>
        <div class="faq">
          {s.faq.map((f) => (
            <details class="faq-item">
              <summary>{f.q}<span class="faq-mark" aria-hidden="true"></span></summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
        <p class="faq-note">Respostas de caráter informativo geral; não substituem a análise individual do caso.</p>
      </div>
    </section>

    <section class="s-sec s-sec--white">
      <div class="wrap rel-cols">
        <div>
          <p class="eyebrow"><span class="dot"></span>Serviços relacionados</p>
          <h2>Explore em {n.label}</h2>
          <ul class="rel">
            <li><a href={n.href}><strong>Visão geral: {n.label}</strong><Icon name="arrow-right" size={16} /></a></li>
            {siblings.map((x) => (
              <li><a href={`/areas-de-atuacao/${x.nucleo}/${x.slug}/`}>{x.label}<Icon name="arrow-right" size={16} /></a></li>
            ))}
          </ul>
        </div>
        <div>
          <p class="eyebrow"><span class="dot"></span>Conteúdos relacionados</p>
          <h2>Aprofunde</h2>
          <ul class="rel">
            {n.related.map((r) => <li><a href={r.href}>{r.label}<Icon name="arrow-right" size={16} /></a></li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="s-sec s-sec--navy">
      <div class="wrap cta-inner">
        <div>
          <h2 class="cta-title">Entenda os riscos e as medidas possíveis para o seu caso</h2>
          <p class="cta-text">Entre em contato para uma análise inicial da situação e dos documentos disponíveis.</p>
        </div>
        <div class="cta-actions">
          <a class="btn btn--primary" href="/contato/">Solicitar atendimento</a>
          <a class="btn btn--ghost-light" href={waHref} target="_blank" rel="noopener noreferrer">Falar no WhatsApp</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* SubPage — identidade própria (hero compacto claro), sistema compartilhado. */
  .sub :where(h2) { font-size: var(--text-2xl); color: var(--color-ink); margin-top: var(--space-2); }

  .s-hero {
    background: var(--surface-warm);
    padding-block: var(--section-y-sm);
    border-bottom: 1px solid var(--border-subtle);
  }
  .s-hero .crumbs { margin-bottom: var(--space-5); }
  .s-hero h1 { font-size: var(--text-3xl); color: var(--color-ink); margin-top: var(--space-3); max-width: 20ch; }
  .s-hero-desc { margin-top: var(--space-4); color: var(--color-text); font-size: var(--text-md); line-height: var(--leading-relaxed); max-width: var(--measure-narrow); }
  .cta-row { margin-top: var(--space-6); display: flex; flex-wrap: wrap; gap: var(--space-3); }

  .s-sec { padding-block: var(--section-y); }
  .s-sec--white { background: var(--surface); }
  .s-sec--paper { background: var(--surface-subtle); }
  .s-sec--navy { background: var(--surface-strong); color: var(--color-text-on-dark); }
  .s-sec--navy :where(h2) { color: #fff; }
  .s-sec .lead { margin-top: var(--space-4); color: var(--color-text); font-size: var(--text-md); line-height: var(--leading-relaxed); max-width: var(--measure); }

  .two-col { display: grid; gap: var(--space-10); grid-template-columns: 1fr; }
  @media (min-width: 860px) { .two-col { grid-template-columns: 1fr 1fr; gap: var(--space-16); } }
  .check { list-style: none; padding: 0; margin: var(--space-5) 0 0; display: flex; flex-direction: column; gap: var(--space-3); }
  .check li { display: flex; gap: var(--space-3); align-items: flex-start; color: var(--color-text); line-height: var(--leading-normal); }
  .ck { color: var(--color-green-strong); flex: none; margin-top: 3px; }

  .risk-grid { list-style: none; padding: 0; margin: var(--space-5) 0 0; display: grid; gap: var(--space-4); grid-template-columns: 1fr; }
  @media (min-width: 720px) { .risk-grid { grid-template-columns: repeat(3, 1fr); } }
  .risk-grid li {
    display: flex; gap: var(--space-3); align-items: flex-start; background: var(--surface);
    border: 1px solid var(--border-subtle); border-radius: var(--radius-md); padding: var(--space-4) var(--space-5);
    color: var(--color-text); font-size: var(--text-sm); line-height: var(--leading-normal);
  }
  .rk { color: var(--color-warn); flex: none; margin-top: 2px; }

  .s-cta-mid { background: var(--color-green-tint); border-block: 1px solid var(--border-green-subtle); }
  .cta-mid-inner { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: var(--space-4); padding-block: var(--space-6); }
  .cta-mid-inner p { font-family: var(--font-display); font-size: var(--text-lg); color: var(--color-ink); }

  .rel-cols { display: grid; gap: var(--space-10); grid-template-columns: 1fr; }
  @media (min-width: 860px) { .rel-cols { grid-template-columns: 1fr 1fr; gap: var(--space-16); } }
  .rel { list-style: none; padding: 0; margin: var(--space-5) 0 0; display: flex; flex-direction: column; gap: var(--space-3); }
  .rel a {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-4);
    padding: var(--space-4) var(--space-5); background: var(--surface); border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md); text-decoration: none; color: var(--color-ink); font-weight: var(--weight-medium);
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .rel a:hover { border-color: var(--color-green); color: var(--color-green-strong); }
  .rel strong { font-weight: var(--weight-semibold); }

  .cta-inner { display: grid; gap: var(--space-6); grid-template-columns: 1fr; align-items: center; }
  @media (min-width: 900px) { .cta-inner { grid-template-columns: 1.6fr 1fr; gap: var(--space-10); } }
  .cta-title { color: #fff; font-size: var(--text-2xl); line-height: var(--leading-snug); max-width: 22ch; }
  .cta-text { margin-top: var(--space-4); color: var(--color-text-on-dark-muted); line-height: var(--leading-normal); max-width: var(--measure-narrow); }
  .cta-actions { display: flex; flex-wrap: wrap; gap: var(--space-3); }
</style>
